@using Elib2Ebook.DomainServices.Configs
@using Elib2Ebook.DomainServices.Extensions
@using Elib2EbookWeb.Misc
@inject IJSRuntime JsRuntime
@inject ISnackbar Snackbar

<div class="book-form">
    <!-- URL Input -->
    <div class="form-section">
        <label class="google-label" for="url-input">Ссылка на книгу</label>
        <div class="google-textfield">
            <input id="url-input" type="text" class="google-input"
                   placeholder="https://example.com/book/123"
                   autofocus
                   @bind="@_url"
                   @bind:event="oninput"/>
            <div class="google-input-underline"></div>
        </div>
    </div>

    <!-- Format Selection -->
    <div class="form-section">
        <label class="google-label">Формат</label>
        <div class="format-cards">
            <button type="button"
                    class="format-card @GetChipClass("epub")"
                    @onclick='(() => ToggleFormat("epub"))'>
                <div class="format-card-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 9H9V9h10v2zm-4 4H9v-2h6v2zm4-8H9V5h10v2z"/>
                    </svg>
                </div>
                <div class="format-card-label">EPUB</div>
            </button>
            <button type="button"
                    class="format-card @GetChipClass("fb2")"
                    @onclick='(() => ToggleFormat("fb2"))'>
                <div class="format-card-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 18H6V4h2v8l2.5-1.5L13 12V4h5v16z"/>
                    </svg>
                </div>
                <div class="format-card-label">FB2</div>
            </button>
            <button type="button"
                    class="format-card @GetChipClass("cbz")"
                    @onclick='(() => ToggleFormat("cbz"))'>
                <div class="format-card-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                    </svg>
                </div>
                <div class="format-card-label">CBZ</div>
            </button>
            <button type="button"
                    class="format-card @GetChipClass("txt")"
                    @onclick='(() => ToggleFormat("txt"))'>
                <div class="format-card-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/>
                    </svg>
                </div>
                <div class="format-card-label">TXT</div>
            </button>
        </div>
    </div>

    <!-- Login (объединённый блок логина и пароля) -->
    <div class="form-section">
        <div class="auth-label">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
            </svg>
            <span>Авторизация</span>
        </div>
        <div class="auth-group">
            <div class="auth-input-wrapper">
                <svg class="auth-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                </svg>
                <input type="text" class="auth-input" placeholder="Логин"
                       @bind="@_options.Login"
                       @bind:event="oninput"/>
            </div>
            <div class="auth-input-wrapper">
                <svg class="auth-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z"/>
                </svg>
                <input id="password-input" type="@GetPasswordType()" class="auth-input" placeholder="Пароль"
                       @bind="@_options.Password"
                       @bind:event="oninput"/>
                <button type="button" class="auth-password-toggle" @onclick="ShowPassword"
                        aria-label="Show password">
                    @if (_isShow)
                    {
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                        </svg>
                    }
                    else
                    {
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/>
                        </svg>
                    }
                </button>
            </div>
        </div>
    </div>

    <!-- Chapter Range -->
    <div class="form-section">
        <label class="google-label">Диапазон глав</label>
        <div class="radio-group">
            <button type="button"
                    class="google-radio @GetRadioClass(false)"
                    @onclick="() => OnSwitch(false)">
                <span class="radio-circle @GetCircleClass(false)"></span>
                По номеру
            </button>
            <button type="button"
                    class="google-radio @GetRadioClass(true)"
                    @onclick="() => OnSwitch(true)">
                <span class="radio-circle @GetCircleClass(true)"></span>
                По названию
            </button>
        </div>

        @if (_startEndCSwitcher)
        {
            <div class="range-fields">
                <div class="google-textfield range-field">
                    <input type="text" class="google-input" placeholder="Глава от"
                           @bind="@_options.StartName"
                           @bind:event="oninput"/>
                    <div class="google-input-underline"></div>
                </div>
                <div class="google-textfield range-field">
                    <input type="text" class="google-input" placeholder="Глава до"
                           @bind="@_options.EndName"
                           @bind:event="oninput"/>
                    <div class="google-input-underline"></div>
                </div>
            </div>
        }
        else
        {
            <div class="range-fields">
                <div class="google-textfield range-field">
                    <input type="text" inputmode="numeric" pattern="-?[0-9]*" class="google-input" placeholder="Глава от"
                           @bind="@_startNumStr"
                           @bind:event="oninput"/>
                    <div class="google-input-underline"></div>
                </div>
                <div class="google-textfield range-field">
                    <input type="text" inputmode="numeric" pattern="-?[0-9]*" class="google-input" placeholder="Глава до"
                           @bind="@_endNumStr"
                           @bind:event="oninput"/>
                    <div class="google-input-underline"></div>
                </div>
            </div>
        }
    </div>

    <!-- Action Buttons -->
    <div class="form-section form-actions">
        @if (_onGenerate)
        {
            <div class="google-button google-button-disabled full-width">
                <div class="button-content">
                    @if (!string.IsNullOrWhiteSpace(_log))
                    {
                        <span class="button-log">@_log</span>
                    }
                    else
                    {
                        <div class="google-spinner"></div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="button-group">
                <button type="button" class="google-button google-button-primary full-width"
                        @onclick="WithImages"
                        disabled="@_onGenerate">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="margin-right: 8px;">
                        <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
                    </svg>
                    Скачать
                </button>
                <div class="split-menu">
                    <button type="button" class="split-toggle" @onclick="ToggleMenu" aria-label="More">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M7 10l5 5 5-5z"/>
                        </svg>
                    </button>
                    @if (_showMenu)
                    {
                        <div class="split-dropdown" @onclick="NoImages">
                            <div class="dropdown-item">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="margin-right: 12px;">
                                    <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                                </svg>
                                Скачать без картинок
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    private readonly Options _options = new();
    private readonly List<string> _formats = [];
    private ActionLogger _logger;
    private bool _onGenerate;
    private string _log;
    private bool _startEndCSwitcher;
    private bool _isShow;
    private bool _showMenu;
    private string _url;
    private int? _startNum;
    private int? _endNum;
    private string _startNumStr = "";
    private string _endNumStr = "";

    [Parameter]
    public required Func<Options, ILogger, Task> OnClick { get; set; }

    private string GetChipClass(string format)
        => _formats.Contains(format) ? "format-card-selected" : "";

    private string GetPasswordType()
        => _isShow ? "text" : "password";

    private string GetRadioClass(bool switcher)
        => switcher == _startEndCSwitcher ? "radio-selected" : "";

    private string GetCircleClass(bool switcher)
        => switcher == _startEndCSwitcher ? "circle-selected" : "";

    private void ToggleFormat(string format)
    {
        if (_formats.Contains(format))
            _formats.Remove(format);
        else
            _formats.Add(format);
    }

    private void ShowPassword()
    {
        _isShow = !_isShow;
    }

    private void ToggleMenu()
    {
        _showMenu = !_showMenu;
    }

    private async Task WithImages()
    {
        _showMenu = false;
        _options.NoImage = false;
        await Download();
    }

    private async Task NoImages()
    {
        _showMenu = false;
        _options.NoImage = true;
        await Download();
    }

    private async Task Download()
    {
        if (string.IsNullOrWhiteSpace(_url))
        {
            Snackbar.Add("Укажите ссылку на книгу", Severity.Error);
            return;
        }

        if (_formats.Count == 0)
        {
            Snackbar.Add("Выберите формат", Severity.Error);
            return;
        }

        _options.Format = _formats;
        _options.Url = new[] { _url };

        if (int.TryParse(_startNumStr, out var startNum))
            _options.Start = startNum;
        if (int.TryParse(_endNumStr, out var endNum))
            _options.End = endNum;

        _onGenerate = true;
        _showMenu = false;
        _logger = new ActionLogger(str =>
        {
            _log = str.Crop(300);
            InvokeAsync(StateHasChanged);
        });

        await OnClick(_options, _logger);
        _onGenerate = false;
    }

    private void OnSwitch(bool value)
    {
        _startEndCSwitcher = value;
        _options.Start = null;
        _options.End = null;
        _options.StartName = null;
        _options.EndName = null;
        _startNum = null;
        _endNum = null;
        _startNumStr = "";
        _endNumStr = "";
    }
}
